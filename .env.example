# ─── Application ───────────────────────────────────────────────
ENVIRONMENT=development
PROJECT_NAME="Extract AI"
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_super_secret_dev_key_do_not_use_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

# ─── Database ──────────────────────────────────────────────────
POSTGRES_USER=extract
POSTGRES_PASSWORD=extract
POSTGRES_DB=extract_ai
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Override the whole URL if you are not using the compose Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# ─── LLM provider ──────────────────────────────────────────────
# Which provider to use for structured extraction: openai or anthropic
LLM_PROVIDER=openai
# Skip live LLM calls and return a deterministic stub (local dev / CI).
LLM_MOCK=false
# Prompt strategy: zero_shot | few_shot | cot (chain-of-thought)
LLM_PROMPT_STRATEGY=zero_shot
LLM_MAX_RETRIES=2

# OpenAI (GPT-4o)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
# Back-compat: also forces the stub when true.
OPENAI_MOCK=false

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# ─── OCR ───────────────────────────────────────────────────────
# easyocr (default) or tesseract
OCR_ENGINE=easyocr
OCR_LANGUAGES=en
# Below this mean-confidence, the pipeline falls back to Tesseract
OCR_CONFIDENCE_THRESHOLD=0.45

# ─── Uploads ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
STORAGE_BACKEND=local
STORAGE_DIR=/app/storage
# AWS S3 (when STORAGE_BACKEND=s3) — not required for local dev
# AWS_S3_BUCKET=
# AWS_REGION=
